# Google OAuth (from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Service Account for Speech-to-Text (path to JSON key file)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# GCS bucket for long audio (>1 min). Optional; if unset, recordings > ~30s may fail.
GCS_BUCKET=your-bucket-name

# OpenAI for summarization and action suggestions
OPENAI_API_KEY=your_openai_api_key_here

# App URLs (for OAuth redirect)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Session secret (generate a random string)
SECRET_KEY=your-secret-key-change-in-production
